docker.enabled = true
process.container = 'ubuntu:22.04'

params {
  // Inputs (Option 2 "easy mode" prefers reads_dir; reads is advanced override)
  reads_dir = null
  reads     = null

  // Default input pattern if user uses --reads (advanced)
  reads     = "data/*_{R1,R2}.fastq.gz"

  // Outputs / resources
  outdir    = "results"
  threads   = 2

  // IRMA
  irma_module = "FLU"

  // Primer trimming (cutadapt)
  trim_primers = false

  // Illumina defaults based on your anchored checks (nested approach)
  primers_5p_r1 = ["AGCAAAAGCAGG"]   // Uni-12 (A-variant)
  primers_5p_r2 = ["AGTAGAAACAAGG"]  // Uni-13

  // Cutadapt tuning (safe defaults for short primers)
  cutadapt_min_overlap = 10
  cutadapt_error_rate  = 0.1
}

profiles {
  apgap {
    // Fill in when APGAP provides workspace + compute environment details:
    // workDir = 'gs://<apgap-bucket>/work'
    // process.executor = 'google-batch'   // or 'k8s'
    // google.project = 'infl-apgap-project-8715'
  }
}
